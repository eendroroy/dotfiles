# Note: intentionally NOT using 'set -e' because the ${__VAR} && cmd pattern
# (used throughout for dry-run / verbose guards) returns exit 1 when __VAR=false,
# which would kill the script under errexit. pipefail + nounset are safe here.
set -uo pipefail

SCRIPT_LOCATION="$( cd "$( dirname "$(realpath "${BASH_SOURCE[0]}")" )" >/dev/null 2>&1 && pwd )"

# directories
readonly __FUNCTIONS_DIR="${SCRIPT_LOCATION}/__functions"
readonly __PREINSTALL_DIR="${SCRIPT_LOCATION}/___preinstall"
readonly __BEFORE_DIR="${SCRIPT_LOCATION}/__before_dots"
readonly __AFTER_DIR="${SCRIPT_LOCATION}/__dots_after"
readonly __DOTS_DIR="${SCRIPT_LOCATION}/__dots"
readonly __UNAME=$(uname)
readonly RELATIVE_PREFIX="__rel__"
readonly ABSOLUTE_PREFIX="__abs__"
readonly PREFIS_LENGTH=${#RELATIVE_PREFIX}

readonly __INSTALLATION_CACHE_FILE="${SCRIPT_LOCATION}/.cache/installation"

# Ensure cache directory exists
mkdir -p "$(dirname "${__INSTALLATION_CACHE_FILE}")"

source "${__DOTS_DIR}/${RELATIVE_PREFIX}.local/share/bash/lib/ansi_text_style.sh.generic.symlink"

for file in "${__FUNCTIONS_DIR}/"*.sh; do
  # shellcheck source=__functions/*.sh
  source "${file}"
done

__VERBOSE=false
__FORCE=false
__STATUS=false
__DRY=false
__USE_BREW=false

__parse_common_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--status ) __STATUS=true   ;;
      -v|--verbose) __VERBOSE=true  ;;
      -f|--force  ) __FORCE=true    ;;
      -n|--dry-run) __DRY=true      ;;
      -b|--brew   ) __USE_BREW=true ;;
      *) ;;
    esac
    shift
  done
}

readonly COMMAND="${1:-help}"
shift || true

case "${COMMAND}" in
  h|help     )                           __help     ;;
  l|list     ) __parse_common_args "$@"; __list     ;;
  i|install  ) __parse_common_args "$@"; __install  ;;
  u|uninstall) __parse_common_args "$@"; __uninstall;;
  up|update  ) __parse_common_args "$@"; __FORCE=true; __install ;;
  *          )                           __help     ;;
esac
